{
  "manifest_version": 3,
  "name": "AnimTube Bridge (SUPER AUTO)",
  "version": "1.1",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_animtube.js"],
      "run_at": "document_start"
    }
  ]
}
